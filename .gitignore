# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyc
.pytest_cache/

# Virtual environments
venv/
.venv/
env/

# Datasets (large, downloadable via src/data_loader.py)
data/raw/*.txt
data/raw/*.csv
data/processed/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep

# Trained models / generated artifacts (reproducible via main.py train)
models/*.joblib
!models/.gitkeep

# Reports generated at run time
reports/*.json
reports/figures/*.png
!reports/figures/.gitkeep

# IDE / OS
.vscode/
.idea/
.DS_Store

# Jupyter
.ipynb_checkpoints/
